{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/common.schema.json",
  "title": "Common CPS assurance object metadata",
  "type": "object",
  "properties": {
    "id": {
      "type": "string"
    },
    "object_type": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "in_review",
        "verified",
        "accepted",
        "retired"
      ]
    },
    "owner": {
      "type": "string"
    },
    "review_cycle": {
      "type": "string",
      "enum": [
        "annual",
        "quarterly",
        "monthly",
        "on_change",
        "on_incident",
        "none"
      ]
    },
    "links": {
      "type": "object",
      "properties": {
        "mitigated_by": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^SF-\\d+$"
          }
        },
        "constrained_by": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^SC-\\d+$"
          }
        },
        "interacts_with": {
          "type": "array",
          "items": {
            "type": "string",
            "pattern": "^SSI-\\d+$"
          }
        },
        "related_to": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "provenance": {
      "type": "object",
      "properties": {
        "basis": {
          "type": "string",
          "pattern": "^\\[(F|I|S),(50|70|80|90)\\]$"
        },
        "verified_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        }
      },
      "required": [
        "basis"
      ]
    }
  },
  "required": [
    "id",
    "object_type",
    "status",
    "owner",
    "provenance"
  ]
}
